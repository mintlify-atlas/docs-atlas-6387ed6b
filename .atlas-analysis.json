  "keyFeatures": [
    "Account pooling and load balancing across multiple ChatGPT accounts",
    "OpenAI-compatible proxy endpoints (/v1/* and /backend-api/codex/*)",
    "API key management with rate limits (token, cost, model-based)",
    "Usage tracking with 28-day trends and per-account metrics",
    "Dashboard authentication with password and optional TOTP",
    "Dynamic model registry with automatic upstream sync",
    "OAuth token refresh automation",
    "IP-based firewall rules",
    "Audio transcription compatibility",
    "Web dashboard for management and monitoring"
  ],
  "publicApiSurface": [
    "POST /v1/chat/completions",
    "POST /v1/responses",
    "GET /v1/models",
    "POST /v1/audio/transcriptions",
